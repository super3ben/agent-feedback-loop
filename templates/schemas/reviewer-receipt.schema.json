{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "write_complete": { "type": "boolean", "const": true },
    "review_receipt_id": { "type": "string", "minLength": 1 },
    "report_content_id": { "type": "string", "minLength": 1 },
    "report_content": { "type": "string", "minLength": 24 },
    "status": { "type": "string", "enum": ["reviewed", "reviewed_no_lesson"] },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lesson_id": { "type": "string", "minLength": 1 },
          "revision": { "type": "integer", "minimum": 1 },
          "base_revision": { "type": "integer", "minimum": 0 },
          "project_id": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["Major", "Critical", "Blocker"] },
          "responsibility": { "type": "string", "const": "agent_fault" },
          "confidence": { "type": "string", "enum": ["medium", "high"] },
          "causal_chain": { "type": "array", "minItems": 5, "items": { "type": "string", "minLength": 1 } },
          "method_class": { "type": "string", "enum": ["evidence-premise", "requirements-scope", "execution-order", "verification-closure", "state-context", "resource-lifecycle", "communication-handoff", "learning-retrieval", "safety-irreversible"] },
          "class_id": { "type": "string", "minLength": 1 },
          "generalizable": { "type": "boolean" },
          "rule_action": { "type": "string", "enum": ["none", "update_project_rule", "propose_global_rule"] },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "feedback_event_id": { "type": "string", "minLength": 1 },
                "feedback_quote": { "type": "string", "minLength": 1 },
                "referent_event_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
              },
              "required": ["feedback_event_id", "feedback_quote", "referent_event_ids"]
            }
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "repository_lineage_id": { "type": ["string", "null"] },
              "paths": { "type": "array", "items": { "type": "string" } },
              "tools": { "type": "array", "items": { "type": "string" } },
              "task_types": { "type": "array", "items": { "type": "string" } },
              "signals": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["repository_lineage_id", "paths", "tools", "task_types", "signals"]
          },
          "card": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "when": { "type": "string", "minLength": 1 },
              "must_do": { "type": "string", "minLength": 1 },
              "must_not": { "type": "string", "minLength": 1 },
              "verify": { "type": "string", "minLength": 1 },
              "why": { "type": "string", "minLength": 1 },
              "exception": { "type": "string", "minLength": 1 },
              "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "verify_predicate": { "type": ["string", "null"] },
              "gate_predicate": { "type": ["string", "null"] }
            },
            "required": ["when", "must_do", "must_not", "verify", "why", "exception", "source_ids", "verify_predicate", "gate_predicate"]
          },
          "decision_timeline": { "type": "array", "items": { "type": "string" } },
          "counterfactual_checkpoint": { "type": ["string", "null"] },
          "impact_scope": { "type": ["string", "null"] },
          "stop_condition": { "type": ["string", "null"] },
          "rollback_or_isolation": { "type": ["string", "null"] },
          "global_promotion_evidence": { "type": "array", "items": { "type": "string" } },
          "effectiveness": {
            "anyOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "previous_lesson_id": { "type": "string" },
                  "expected_revision": { "type": "integer" },
                  "application_id": { "type": ["string", "null"] },
                  "delivery_state": { "type": "string" },
                  "was_applicable": { "type": "boolean" },
                  "was_followed": { "type": ["boolean", "null"] },
                  "failure_mode": { "type": "string", "enum": ["not_materialized", "not_selected", "delivery_unconfirmed", "loaded_not_applied", "contract_incomplete", "external_limit", "unknown"] },
                  "control_owner": { "type": "string", "enum": ["capture_adapter", "reviewer_runner", "reviewer", "store", "compiler", "selector", "delivery_adapter", "agent_execution", "lesson_contract", "external", "unknown"] },
                  "corrective_action": { "type": "string" }
                },
                "required": ["previous_lesson_id", "expected_revision", "application_id", "delivery_state", "was_applicable", "was_followed", "failure_mode", "control_owner", "corrective_action"]
              }
            ]
          }
        },
        "required": ["lesson_id", "revision", "base_revision", "project_id", "severity", "responsibility", "confidence", "causal_chain", "method_class", "class_id", "generalizable", "rule_action", "evidence_refs", "scope", "card", "decision_timeline", "counterfactual_checkpoint", "impact_scope", "stop_condition", "rollback_or_isolation", "global_promotion_evidence", "effectiveness"]
      }
    }
  },
  "required": ["write_complete", "review_receipt_id", "report_content_id", "report_content", "status", "lessons"]
}
